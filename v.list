<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE vars
        SYSTEM "https://resources.jetbrains.com/stardust/vars.dtd">

<vars>
    <!-- Kotlin -->
    <var name="kotlinVersion" value="2.4.10"/>
    <var name="kotlinEapVersion" value="2.4.20-Beta2"/>
    <var name="kotlinLatestUrl" value="https://github.com/JetBrains/kotlin/releases/tag/v2.4.0"/>
    <var name="kmpLatestUrl" value="https://github.com/JetBrains/compose-multiplatform/releases"/>
    <var name="languageVersion" value="2.4"/>
    <var name="apiVersion" value="2.4"/>

    <!-- Compose Multiplatform -->
    <var name="org.jetbrains.compose" value="1.11.1"/>
    <var name="org.jetbrains.compose-eap" value="1.12.0-beta02"/>
    <var name="org.jetbrains.androidx.navigation" value="2.9.2"/>
    <var name="org.jetbrains.androidx.lifecycle" value="2.11.0-beta01"/>
    <var name="org.jetbrains.compose.material3.adaptive" value="1.3.0-alpha07"/>
    <var name="org.jetbrains.compose.material3" value="1.11.0-alpha07"/>

    <!-- Jetpack Compose -->
    <var name="androidx.compose" value="1.11.2"/>
    <var name="androidx.compose.material3-stable" value="1.4.0"/>

    <!-- Compose Hot Reload -->
    <var name="foojayResolverConventionVersion" value="1.0.0"/>

    <!-- KGP, AGP, Xcode -->
    <var name="minGradleVersion" value="7.6.3"/>
    <var name="maxGradleVersion" value="9.5.0"/>

    <var name="minAndroidGradleVersion" value="8.5.2"/>
    <var name="maxAndroidGradleVersion" value="9.1.0"/>

    <var name="xcode" value="26.4"/>

    <!-- Libraries and Frameworks -->
    <var name="coroutinesVersion" value="1.11.0"/>
    <var name="serializationVersion" value="1.11.0"/>
    <var name="sqlDelightVersion" value="2.3.2"/>
    <var name="ktorVersion" value="3.5.1"/>
    <var name="dateTimeVersion" value="0.8.0"/>
    <var name="koinVersion" value="4.2.2"/>
    <var name="skieVersion" value="0.10.12"/>
    <var name="kmpncVersion" value="1.0.3"/>
    <var name="kspVersion" value="2.3.10"/>
    <var name="vanniktechPublishPlugin" value="0.36.0"/>

    <var name="rubyVersion" value="3.4.7"/>
    <var name="npmPublishPlugin" value="3.7.0"/>
</vars>
